#!/usr/bin/env python3
# Usage: ./check-stats prod
#        ./check-stats test
#
# Fetches record.log over FTP and summarizes usage counts.
# Requires FTP_USER and FTP_PASS env vars (source ../eukhost/eukenv or similar).

import argparse
import ftplib
import io
import os
import ssl
from collections import Counter

# The FTP cert is issued for *.theukhost.net (the shared hosting domain),
# not ftp.hamadi.net, so connect via the actual server hostname to allow
# full TLS verification (chain + hostname).
_ftp_host = os.environ.get("FTP_HOST", "firefly.theukhost.net")
_ftp_user = os.environ["FTP_USER"]
_ftp_pass = os.environ["FTP_PASS"]

ENVIRONMENTS = {
    "prod": {
        "host":        _ftp_host,
        "user":        _ftp_user,
        "password":    _ftp_pass,
        "remote_path": "public_html/bmwupdate.hamadi.net",
    },
    "test": {
        "host":        _ftp_host,
        "user":        _ftp_user,
        "password":    _ftp_pass,
        "remote_path": "public_html/bmwupdate-test.hamadi.net",
    },
}


def fetch_log(env):
    ctx = ssl.create_default_context()

    remote = env["remote_path"] + "/record.log"
    buf = io.BytesIO()
    with ftplib.FTP_TLS(context=ctx) as ftp:
        ftp.connect(env["host"])
        ftp.auth()
        ftp.login(env["user"], env["password"])
        ftp.prot_p()
        ftp.set_pasv(True)
        ftp.retrbinary(f"RETR {remote}", buf.write)
    return buf.getvalue().decode("utf-8", errors="replace")


def main():
    parser = argparse.ArgumentParser(description="Summarize record.log usage stats.")
    parser.add_argument("environment", choices=ENVIRONMENTS.keys())
    args = parser.parse_args()

    env = ENVIRONMENTS[args.environment]
    print(f"Fetching record.log from {args.environment} ({env['host']}/{env['remote_path']}) ...\n")

    text = fetch_log(env)
    lines = [l for l in text.splitlines() if l.strip()]

    event_counts = Counter()
    download_files = Counter()

    for line in lines:
        parts = line.split("\t")
        if len(parts) < 2:
            continue
        event = parts[1]
        file_id = parts[2] if len(parts) > 2 else ""
        event_counts[event] += 1
        if event == "bin_download" and file_id:
            download_files[file_id] += 1

    print(f"Total events: {len(lines)}")
    for event, count in event_counts.most_common():
        print(f"  {event:15s} {count}")

    if download_files:
        print("\nbin_download breakdown by file:")
        for file_id, count in download_files.most_common():
            print(f"  {file_id:12s} {count}")


if __name__ == "__main__":
    main()
